{
  "name": "clean-my-home",
  "version": "0.1.0",
  "description": "See which AI coding agents are eating your home-directory disk space — a local dashboard with treemap, donut and ranked bars.",
  "type": "module",
  "bin": {
    "clean-my-home": "bin.js"
  },
  "workspaces": [
    "backend",
    "web"
  ],
  "engines": {
    "node": ">=18"
  },
  "files": [
    "bin.js",
    "backend/dist",
    "public",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "concurrently -n backend,web \"npm run dev -w backend\" \"npm run dev -w web\"",
    "build": "npm run build -w web && npm run build -w backend",
    "start": "node bin.js",
    "test": "npm run test -w backend",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "cli",
    "disk-usage",
    "ai",
    "agents",
    "claude",
    "cursor",
    "codex",
    "copilot",
    "dashboard",
    "treemap"
  ],
  "author": "BaoXuebin",
  "license": "MIT",
  "homepage": "https://github.com/BaoXuebin/clean-my-home",
  "repository": {
    "type": "git",
    "url": "https://github.com/BaoXuebin/clean-my-home.git"
  },
  "bugs": {
    "url": "https://github.com/BaoXuebin/clean-my-home/issues"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
